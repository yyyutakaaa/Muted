<Window x:Class="Muted.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Muted"
        Icon="pack://siteoforigin:,,,/icon.png"
        Width="580"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="{StaticResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="14"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="PowerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="110" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="38" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="PowerSurface"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-3,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter TargetName="PowerSurface" Property="Fill" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="PowerSurface" Property="Stroke" Value="#B5ACFF" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="PowerSurface" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="34"
                                                          ShadowDepth="0"
                                                          Color="{StaticResource AccentColor}"
                                                          Opacity="0.75" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PowerSurface" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PowerSurface" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#0E1015"
              MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                <Image Width="30" Height="30"
                       Source="pack://siteoforigin:,,,/icon.png"
                       Stretch="Uniform" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Text="Muted" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                <Button Style="{StaticResource ChromeButtonStyle}"
                        Content="—"
                        Click="MinimizeButton_OnClick"
                        ToolTip="Minimize"
                        AutomationProperties.Name="Minimize window" />
                <Button Style="{StaticResource ChromeButtonStyle}"
                        Content="×"
                        Click="CloseButton_OnClick"
                        ToolTip="Close"
                        AutomationProperties.Name="Close window" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="34,26,34,30">
            <StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <Image Width="78" Height="78"
                           Source="pack://siteoforigin:,,,/icon.png"
                           Stretch="Uniform" />
                    <TextBlock Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="RNNoise microphone" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Style="{StaticResource CaptionStyle}"
                               Text="Real-time noise suppression" />
                    <Grid Margin="0,20,0,0" HorizontalAlignment="Center">
                        <Ellipse Width="110" Height="110"
                                 Stroke="{StaticResource AccentBrush}"
                                 StrokeThickness="2.5"
                                 Opacity="0"
                                 IsHitTestVisible="False"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.6" To="0"
                                                                         Duration="0:0:1.8" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         From="1" To="1.5"
                                                                         Duration="0:0:1.8" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         From="1" To="1.5"
                                                                         Duration="0:0:1.8" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <RemoveStoryboard BeginStoryboardName="PulseStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Button Style="{StaticResource PowerButtonStyle}"
                                Content="⏻"
                                Command="{Binding ToggleCommand}"
                                ToolTip="Start or stop RNNoise"
                                AutomationProperties.Name="Start or stop RNNoise" />
                    </Grid>
                    <TextBlock Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding StatusText}" />
                </StackPanel>

                <Border Margin="0,28,0,0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Live signal" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{StaticResource SuccessBrush}"
                                         Opacity="{Binding VoiceProbability}" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
                                           Style="{StaticResource CaptionStyle}"
                                           Text="VOICE DETECTED" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,16,0,6"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="MICROPHONE (RAW)" />
                        <ProgressBar Style="{StaticResource MeterStyle}"
                                     Maximum="1"
                                     Value="{Binding InputLevel, Mode=OneWay}"
                                     Foreground="{StaticResource WarningBrush}" />

                        <TextBlock Margin="0,14,0,6"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="FILTERED OUTPUT (NOISE REMOVED)" />
                        <ProgressBar Style="{StaticResource MeterStyle}"
                                     Maximum="1"
                                     Value="{Binding OutputLevel, Mode=OneWay}"
                                     Foreground="{StaticResource SuccessBrush}" />

                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                    <Setter Property="Text" Value="Start RNNoise to see the live microphone signal." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="The gap between both bars is the background noise being removed." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Audio devices" />

                        <TextBlock Margin="0,18,0,6"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="MICROPHONE INPUT" />
                        <ComboBox ItemsSource="{Binding InputDevices}"
                                  SelectedItem="{Binding SelectedInput}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding CanSelectInput}"
                                  AutomationProperties.Name="Microphone input" />

                        <TextBlock Margin="0,18,0,6"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="VIRTUAL CABLE OUTPUT" />
                        <ComboBox ItemsSource="{Binding OutputDevices}"
                                  SelectedItem="{Binding SelectedOutput}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding IsStopped}"
                                  AutomationProperties.Name="Virtual cable output" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource CaptionStyle}"
                                   TextWrapping="Wrap"
                                   Text="Select the playback side of your virtual audio cable." />
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="14"
                        CornerRadius="12"
                        Background="#2A151A"
                        BorderBrush="#66313B"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
